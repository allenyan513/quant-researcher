# quant-researcher environment configuration.
# Copy to `.env` and fill in your values. Never commit `.env` (see .gitignore + D8).

# ---- Required ----

# Postgres DSN (Neon / Supabase / any managed Postgres).
# Paste whatever the provider gives you — `postgres://...` or `postgresql://...`
# is auto-normalized to the psycopg v3 dialect (`postgresql+psycopg://`).
QR_DATABASE_URL=

# ---- Required at MA (data warehouse ingestion) ----

FMP_API_KEY=

# ---- Optional ----

# Alpha Vantage API key — earnings-call transcripts (`qr data refresh --scope
# transcript`). FMP gates transcripts behind a premium tier; AV serves them on
# the free key (~25 req/day). Free signup: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# FRED API key (10Y Treasury yield → WACC risk-free rate). Falls back to 4.5% if absent.
FRED_API_KEY=

# IBKR Flex Query credentials (needed at ME for live holdings; CSV holdings work without).
FLEX_TOKEN_KEY=
FLEX_QUERY_ID_LIVE=
FLEX_QUERY_ID_HISTORICAL=
